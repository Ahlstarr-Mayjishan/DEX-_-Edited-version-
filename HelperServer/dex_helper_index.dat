return {
    LyricsFormat = "sbv",
    LyricsData = "0:00:45.700,0:00:47.352\nLost\n\n0:00:47.352,0:00:51.943\nIn an eternal plane\n\n0:00:51.943,0:00:56.470\nIn an unfamiliar place\n\n0:00:56.470,0:01:01.357\nWith our homes long forgotten\n\n0:01:01.357,0:01:04.034\nFor so long\n\n0:01:04.034,0:01:05.763\nDeath\n\n0:01:05.763,0:01:10.174\nWhen the story\'s over\n\n0:01:10.174,0:01:15.000\nWith our misfortunate end\n\n0:01:15.000,0:01:19.294\nYet we aren\'t given the pleasure\n\n0:01:19.294,0:01:23.479\nOf a final tragedy\n\n0:01:23.479,0:01:28.083\nImmortals\n\n0:01:28.083,0:01:32.687\nThat want to die\n\n0:01:32.687,0:01:37.007\nAll routes destroyed\n\n0:01:37.007,0:01:49.600\nYet we are refusing this destiny\n\n0:01:49.600,0:01:58.634\nTake control of your life\n\n0:01:58.634,0:02:08.123\nDetermination brings you\n\n0:02:08.123,0:02:17.023\nCloser to the end of this world\n\n0:02:17.023,0:02:19.048\nYou never prosper\n\n0:02:19.048,0:02:21.551\nIn a world that fights at every step\n\n0:02:21.551,0:02:23.551\nYou need a savior\n\n0:02:23.551,0:02:26.338\nRunning to the end of ever after\n\n0:02:26.338,0:02:28.441\nDeadly luster\n\n0:02:28.441,0:02:30.944\nYour path destined to self-destruction\n\n0:02:30.944,0:02:32.944\nDeath defying dedication\n\n0:02:32.944,0:02:36.310\nDetermination never questioned\n\n0:02:36.310,0:02:38.697\nSo long forgotten\n\n0:02:38.697,0:02:40.787\nThe grace of death\n\n0:02:40.787,0:02:43.293\nYour final stand\n\n0:02:43.293,0:02:45.473\nYet you don\'t repent\n\n0:02:45.473,0:02:47.795\nAn endless sadness\n\n0:02:47.795,0:02:50.169\nDisrupted realms\n\n0:02:50.169,0:02:52.134\nDestruction\n\n0:02:52.134,0:02:53.799\nYour own death\n\n0:02:53.799,0:03:00.052\nTake what is left of your will\n\n0:03:00.052,0:03:04.681\nAnd go change the narrative\n\n0:03:04.681,0:03:09.168\n\'Cause you cannot give in\n\n0:03:09.168,0:03:13.185\nFor it\'s time for this song to end\n\n0:03:13.185,0:03:17.827\nImmortals\n\n0:03:17.827,0:03:22.224\nThat want to die\n\n0:03:22.224,0:03:26.534\nAll routes destroyed\n\n0:03:26.534,0:03:39.427\nYet we are refusing this destiny\n\n0:03:39.427,0:03:48.349\nTake control of your life\n\n0:03:48.349,0:03:57.831\nDetermination brings you\n\n0:03:57.831,0:04:06.829\nCloser to the end of this world\n\n0:04:06.829,0:04:10.930\nThere must be a way\n\n0:04:10.930,0:04:16.126\nThis cannot be the end, no\n\n0:04:16.126,0:04:19.969\nYour desire for freedom\n\n0:04:19.969,0:04:25.255\nIt must not be in vain\n\n0:04:25.255,0:04:30.735\nBring this dimension to an end\n\n0:04:30.735,0:04:33.805\nRepay the old mistakes\n\n0:04:33.805,0:04:38.900\nAnd so long as your lungs still breathe\n\n0:04:38.900,0:04:48.092\nIT DOES NOT END HERE.\n",
    Target = game.SoundService.MusicFolder.ItDoesntEndHere
